# Shared frontend override if both forms are handled by one custom backend route.
# VITE_FORM_ENDPOINT=https://your-backend.example.com/forms

# Optional per-form frontend overrides.
# VITE_CONTACT_FORM_ENDPOINT=https://your-app.pages.dev/api/contact
# VITE_NEWSLETTER_FORM_ENDPOINT=https://your-app.pages.dev/api/newsletter

# Resend API key used by both the local Express API and Cloudflare Pages Functions.
RESEND_API_KEY=re_xxxxxxxxx

# Inbox that will receive contact form and newsletter submissions.
CONTACT_FORM_RECIPIENT=studio-inbox@example.com
NEWSLETTER_FORM_RECIPIENT=studio-inbox@example.com

# Verified sender addresses on the sending domain.
CONTACT_FORM_SENDER=website@atlagic.org
NEWSLETTER_FORM_SENDER=newsletter@atlagic.org

# Optional shared fallbacks.
# FORM_RECIPIENT=studio-inbox@example.com
# FORM_SENDER=website@atlagic.org
